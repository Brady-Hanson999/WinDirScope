{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "WinDirScope",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "open": true,
        "confirm": true,
        "message": true
      },
      "shell": {
        "open": true
      },
      "window": {
        "create": true,
        "show": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.windirscope.app",
      "icon": [
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "WinDirScope",
        "width": 960,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ]
  }
}
